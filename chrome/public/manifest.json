{
  "name": "Kunnskap",
  "description": "A simple browser extension randomly inserting vocabulary or knowledge questions.",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "index.html"
  },
  "permissions": ["alarms", "storage", "nativeMessaging", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["katex/katex.min.js", "contentScript.js"],
      "css": ["katex/katex.min.css"]
    }
  ]
}
